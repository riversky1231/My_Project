<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.defensemanagement.mapper.TeacherProfileMapper">

    <resultMap id="TeacherProfileResultMap" type="com.example.defensemanagement.entity.TeacherProfile">
        <id property="id" column="id"/>
        <result property="teacherId" column="teacher_id"/>
        <result property="researchDirection" column="research_direction"/>
        <result property="enrollmentRequirements" column="enrollment_requirements"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <select id="findByTeacherId" resultMap="TeacherProfileResultMap">
        SELECT * FROM teacher_profile WHERE teacher_id = #{teacherId}
    </select>

    <insert id="insert" parameterType="com.example.defensemanagement.entity.TeacherProfile" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO teacher_profile (teacher_id, research_direction, enrollment_requirements)
        VALUES (#{teacherId}, #{researchDirection}, #{enrollmentRequirements})
    </insert>

    <update id="update" parameterType="com.example.defensemanagement.entity.TeacherProfile">
        UPDATE teacher_profile
        SET research_direction = #{researchDirection},
            enrollment_requirements = #{enrollmentRequirements},
            updated_time = CURRENT_TIMESTAMP
        WHERE teacher_id = #{teacherId}
    </update>

</mapper>
