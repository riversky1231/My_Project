<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.defensemanagement.mapper.StudentCommentMapper">

    <resultMap id="StudentCommentMap" type="com.example.defensemanagement.entity.StudentComment">
        <id property="id" column="id"/>
        <result property="studentId" column="student_id"/>
        <result property="year" column="year"/>
        <result property="content" column="content"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
        <association property="student" javaType="com.example.defensemanagement.entity.Student">
            <id property="id" column="student_id"/>
            <result property="studentNo" column="student_no"/>
            <result property="name" column="student_name"/>
            <result property="defenseType" column="defense_type"/>
            <result property="title" column="title"/>
            <result property="summary" column="summary"/>
        </association>
    </resultMap>

    <select id="findByStudentIdAndYear" resultMap="StudentCommentMap">
        SELECT sc.*,
               s.student_no, s.name as student_name, s.defense_type, s.title, s.summary
        FROM student_comment sc
        LEFT JOIN t_student s ON sc.student_id = s.id
        WHERE sc.student_id = #{studentId} AND sc.year = #{year}
    </select>

    <select id="findByGroupIdAndYear" resultMap="StudentCommentMap">
        SELECT sc.*,
               s.student_no, s.name as student_name, s.defense_type, s.title, s.summary
        FROM student_comment sc
        LEFT JOIN t_student s ON sc.student_id = s.id
        WHERE s.defense_group_id = #{groupId} AND sc.year = #{year}
        ORDER BY s.student_no
    </select>

    <insert id="insert" parameterType="com.example.defensemanagement.entity.StudentComment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO student_comment (student_id, year, content)
        VALUES (#{studentId}, #{year}, #{content})
    </insert>

    <update id="update" parameterType="com.example.defensemanagement.entity.StudentComment">
        UPDATE student_comment
        SET content = #{content}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM student_comment WHERE id = #{id}
    </delete>

</mapper>
