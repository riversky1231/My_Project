<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.defensemanagement.mapper.EvaluationItemMapper">

    <resultMap id="EvaluationItemMap" type="com.example.defensemanagement.entity.EvaluationItem">
        <id property="id" column="id"/>
        <result property="defenseType" column="defense_type"/>
        <result property="itemName" column="item_name"/>
        <result property="weight" column="weight"/>
        <result property="maxScore" column="max_score"/>
        <result property="displayOrder" column="display_order"/>
    </resultMap>

    <select id="findByType" resultMap="EvaluationItemMap">
        SELECT * FROM evaluation_item
        WHERE defense_type = #{defenseType}
        ORDER BY display_order ASC, id ASC
    </select>

    <insert id="insert" parameterType="com.example.defensemanagement.entity.EvaluationItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO evaluation_item (defense_type, item_name, weight, max_score, display_order)
        VALUES (#{defenseType}, #{itemName}, #{weight}, #{maxScore}, #{displayOrder})
    </insert>

    <update id="update" parameterType="com.example.defensemanagement.entity.EvaluationItem">
        UPDATE evaluation_item
        <set>
            <if test="defenseType != null">defense_type = #{defenseType},</if>
            <if test="itemName != null">item_name = #{itemName},</if>
            <if test="weight != null">weight = #{weight},</if>
            <if test="maxScore != null">max_score = #{maxScore},</if>
            <if test="displayOrder != null">display_order = #{displayOrder},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM evaluation_item WHERE id = #{id}
    </delete>

    <delete id="deleteAllByType" parameterType="string">
        DELETE FROM evaluation_item WHERE defense_type = #{defenseType}
    </delete>

</mapper>

