<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.defensemanagement.mapper.CommentMapper">

    <select id="findByGroupId" resultType="com.example.defensemanagement.entity.Comment">
        SELECT id, content, group_id as groupId
        FROM comment 
        WHERE group_id = #{groupId}
    </select>

    <insert id="insert" parameterType="com.example.defensemanagement.entity.Comment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO comment (content, group_id)
        VALUES (#{content}, #{groupId})
    </insert>

    <update id="update" parameterType="com.example.defensemanagement.entity.Comment">
        UPDATE comment 
        SET content = #{content}, group_id = #{groupId}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM comment WHERE id = #{id}
    </delete>

    <delete id="deleteByGroupId">
        DELETE FROM comment WHERE group_id = #{groupId}
    </delete>

</mapper>