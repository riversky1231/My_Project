<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.defensemanagement.mapper.StudentFinalScoreMapper">

    <resultMap id="StudentFinalScoreMap" type="com.example.defensemanagement.entity.StudentFinalScore">
        <id property="id" column="id"/>
        <result property="studentId" column="student_id"/>
        <result property="year" column="year"/>
        <result property="advisorScore" column="advisor_score"/>
        <result property="reviewerScore" column="reviewer_score"/>
        <result property="finalDefenseScore" column="final_defense_score"/>
        <result property="totalGrade" column="total_grade"/>
        <result property="adjustmentFactor" column="adjustment_factor"/>
        <result property="groupAvgScore" column="group_avg_score"/>
        <result property="largeGroupScore" column="large_group_score"/>
    </resultMap>

    <select id="findByStudentId" resultMap="StudentFinalScoreMap">
        SELECT * FROM student_final_score
        WHERE student_id = #{studentId}
    </select>

    <select id="findByStudentIdAndYear" resultMap="StudentFinalScoreMap">
        SELECT * FROM student_final_score
        WHERE student_id = #{studentId} AND year = #{year}
    </select>

    <select id="findByStudentIdsAndYear" resultMap="StudentFinalScoreMap">
        SELECT * FROM student_final_score
        WHERE year = #{year}
        <if test="studentIds != null and studentIds.size() > 0">
            AND student_id IN
            <foreach collection="studentIds" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
    </select>

    <insert id="insert" parameterType="com.example.defensemanagement.entity.StudentFinalScore" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO student_final_score
        (student_id, year, advisor_score, reviewer_score, final_defense_score,
         total_grade, adjustment_factor, group_avg_score, large_group_score)
        VALUES
        (#{studentId}, #{year}, #{advisorScore}, #{reviewerScore}, #{finalDefenseScore},
         #{totalGrade}, #{adjustmentFactor}, #{groupAvgScore}, #{largeGroupScore})
    </insert>

    <update id="update" parameterType="com.example.defensemanagement.entity.StudentFinalScore">
        UPDATE student_final_score
        <set>
            <if test="year != null">year = #{year},</if>
            <if test="advisorScore != null">advisor_score = #{advisorScore},</if>
            <if test="reviewerScore != null">reviewer_score = #{reviewerScore},</if>
            <if test="finalDefenseScore != null">final_defense_score = #{finalDefenseScore},</if>
            <if test="totalGrade != null">total_grade = #{totalGrade},</if>
            <if test="adjustmentFactor != null">adjustment_factor = #{adjustmentFactor},</if>
            <if test="groupAvgScore != null">group_avg_score = #{groupAvgScore},</if>
            <if test="largeGroupScore != null">large_group_score = #{largeGroupScore},</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>

