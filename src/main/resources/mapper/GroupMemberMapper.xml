<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.defensemanagement.mapper.GroupMemberMapper">

    <select id="findByGroupId" resultType="com.example.defensemanagement.entity.GroupMember">
        SELECT id, name, group_id as groupId
        FROM group_member 
        WHERE group_id = #{groupId}
    </select>

    <insert id="insert" parameterType="com.example.defensemanagement.entity.GroupMember" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO group_member (name, group_id)
        VALUES (#{name}, #{groupId})
    </insert>

    <update id="update" parameterType="com.example.defensemanagement.entity.GroupMember">
        UPDATE group_member 
        SET name = #{name}, group_id = #{groupId}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM group_member WHERE id = #{id}
    </delete>

    <delete id="deleteByGroupId">
        DELETE FROM group_member WHERE group_id = #{groupId}
    </delete>

</mapper>